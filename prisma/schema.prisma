generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(AUTHOR)
  affiliation  String?
  bio          String?
  isVerified   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Article {
  id            String        @id @default(uuid())
  title         String
  abstract      String
  keywords      String[]
  status        ArticleStatus @default(DRAFT)
  showOnHomepage Boolean      @default(false)
  featuredInIssue Boolean     @default(false)
  manuscriptUrl String?
  publishedUrl  String?
  doi           String?
  issueId       String?
  pageStart     Int?
  pageEnd       Int?
  submittedAt   DateTime?
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
}

model Volume {
  id           String   @id @default(uuid())
  volumeNumber Int      @unique
  year         Int
  createdAt    DateTime @default(now())
}

model Issue {
  id          String    @id @default(uuid())
  volumeId    String
  issueNumber Int
  title       String?
  issuePdfUrl String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([volumeId, issueNumber])
}

model EditorialDecision {
  id         String   @id @default(uuid())
  articleId  String
  editorId   String
  decision   String
  comments   String?
  decidedAt  DateTime @default(now())
  createdAt  DateTime @default(now())
}

model Review {
  id               String          @id @default(uuid())
  articleId        String
  reviewerId       String
  status           ReviewStatus    @default(INVITED)
  recommendation   Recommendation?
  commentsToEditor String?
  commentsToAuthor String?
  qualityRatings   Json?
  dueDate          DateTime?
  submittedAt      DateTime?
  createdAt        DateTime        @default(now())
}

model Submission {
  id             String   @id @default(uuid())
  articleId      String
  submittedBy    String
  coverLetter    String?
  revisionNumber Int      @default(1)
  notes          String?
  createdAt      DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum Role {
  AUTHOR
  REVIEWER
  EDITOR
  ADMIN
}

enum ArticleStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUIRED
  ACCEPTED
  REJECTED
  PUBLISHED
}

enum ReviewStatus {
  INVITED
  ACCEPTED
  DECLINED
  COMPLETED
}

enum Recommendation {
  ACCEPT
  MINOR_REVISION
  MAJOR_REVISION
  REJECT
}